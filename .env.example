# True means the agent will only log what it would do, but will not actually delete anything.
DRY_RUN=true

# URL to AWS Endpoint. Defaults to LocalStack for local development. Unset this for real AWS.
AWS_ENDPOINT_URL=http://localhost:4566

# Target AWS Region for scans.
AWS_REGION=us-east-1

# Path to the local SQLite database for finding persistence.
SENTINEL_DB_PATH=.sentinel.db

# Slack Webhook URL for sending outbound alerts to a specific channel
SLACK_WEBHOOK_URL=

# Slack Signing Secret for verifying inbound HTTP requests from interactive buttons
SLACK_SIGNING_SECRET=
